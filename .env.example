# WeatherAPI.com — https://www.weatherapi.com/ (sign up, copy key from dashboard)
# Vite exposes only variables prefixed with VITE_
VITE_WEATHER_API_KEY=

# First paint: default is Lahore.
# Override with a city name (e.g. "London") if you prefer a fixed default.
# VITE_DEFAULT_LOCATION=Lahore

# If the primary default fails, this is tried next (default auto:ip).
# VITE_FALLBACK_LOCATION=London

# Optional: forecast days (default 3 — matches free tier; paid plans allow more, e.g. 5 or 7)
# VITE_FORECAST_DAYS=5
